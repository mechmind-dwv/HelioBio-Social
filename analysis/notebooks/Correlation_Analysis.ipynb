print(f"n observations: {len(df)}")

# Statistical power (simplified)
from scipy.stats import norm
z_alpha = norm.ppf(0.975)  # Two-tailed, alpha=0.05
z_transform = 0.5 * np.log((1 + corr_pearson) / (1 - corr_pearson))
se = 1 / np.sqrt(len(df) - 3)
z_beta = z_transform / se - z_alpha
power = norm.cdf(z_beta)
print(f"Statistical power (estimated): {power:.2f}")

# Visualize bootstrap distribution
plt.figure(figsize=(10, 5))
plt.hist(bootstrap_corrs, bins=50, alpha=0.7, edgecolor='black')
plt.axvline(corr_pearson, color='red', linestyle='--', linewidth=2, label=f'Observed r={corr_pearson:.3f}')
plt.axvline(ci[0], color='green', linestyle='--', linewidth=1.5, label=f'95% CI')
plt.axvline(ci[1], color='green', linestyle='--', linewidth=1.5)
plt.xlabel('Correlation Coefficient')
plt.ylabel('Frequency')
plt.title('Bootstrap Distribution of Correlation (10,000 iterations)')
plt.legend()
