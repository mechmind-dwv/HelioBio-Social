# ## 2. Data Generation (Simulated for Demo)
# 
# In production, this would load real data from:
# - NOAA SWPC API (Kp index, SSN)
# - Google Trends API (anxiety/depression searches)
# - WHO GHO (mental health statistics)

# %%
def generate_synthetic_data(n_days=730, seed=42):
    """
    Generate synthetic but realistic solar-mental health data
    
    Simulates:
    - Solar activity with ~11-year cycle + short-term variation
    - Mental health indicator with weak correlation to solar + confounders
    - Control variables (temperature, day of week)
    """
    np.random.seed(seed)
    
    # Date range
    dates = pd.date_range('2020-01-01', periods=n_days, freq='D')
    
    # Solar activity (Kp index) - simulated with realistic autocorrelation
    kp = np.zeros(n_days)
    kp[0] = 3.0
    for i in range(1, n_days):
        # Autocorrelation + solar cycle trend + noise
        cycle_component = 0.5 * np.sin(2 * np.pi * i / 365)  # Annual variation
        kp[i] = 0.7 * kp[i-1] + cycle_component + np.random.normal(0, 0.8)
        kp[i] = np.clip(kp[i], 0, 9)  # Kp ranges 0-9
    
    # Sunspot number (correlated with Kp but different dynamics)
    ssn = 50 + 30 * np.sin(2 * np.pi * np.arange(n_days) / (11 * 365)) + np.random.normal(0, 15, n_days)
    ssn = np.clip(ssn, 0, 200)
    
    # Control variables
    temperature = 15 + 10 * np.sin(2 * np.pi * np.arange(n_days) / 365) + np.random.normal(0, 3, n_days)
    day_of_week = dates.dayofweek
    
    # Mental health indicator (anxiety searches)
    # True relationship: weak correlation with Kp (r~0.3) + confounders
    anxiety = np.zeros(n_days)
    for i in range(n_days):
        solar_effect = 0.25 * kp[max(0, i-5)]  # 5-day lag
        seasonal_effect = 5 * np.sin(2 * np.pi * i / 365)  # SAD
        weekend_effect = -3 if day_of_week[i] >= 5 else 0  # Lower on weekends
        temperature_effect = -0.3 * temperature[i]  # Lower in warm weather
        noise = np.random.normal(0, 5)
        
        anxiety[i] = 50 + solar_effect + seasonal_effect + weekend_effect + temperature_effect + noise
        anxiety[i] = np.clip(anxiety[i], 0, 100)
    
    # Create DataFrame
    df = pd.DataFrame({
        'date': dates,
        'kp_index': kp,
        'sunspot_number': ssn,
        'anxiety_searches': anxiety,
        'temperature': temperature,
        'day_of_week': day_of_week
    })
    
    return df

# Generate data
df = generate_synthetic_data(n_days=730)
print(f"\n✓ Generated {len(df)} days of synthetic data")
print(f"Date range: {df['date'].min()} to {df['date'].max()}")
print(f"\nData preview:")
print(df.head())

