# %% [markdown]
# ## 4. Stationarity Testing
# 
# Time series must be stationary for reliable Granger causality testing.
# We use the Augmented Dickey-Fuller (ADF) test.

# %%
def test_stationarity(series, name, alpha=0.05):
    """Test if time series is stationary using ADF test"""
    result = adfuller(series.dropna(), autolag='AIC')
    
    print(f"\n=== Stationarity Test: {name} ===")
    print(f"ADF Statistic: {result[0]:.4f}")
    print(f"p-value: {result[1]:.4f}")
    print(f"Critical Values:")
    for key, value in result[4].items():
        print(f"  {key}: {value:.4f}")
    
    if result[1] < alpha:
        print(f"✓ STATIONARY (reject H0 of unit root, p={result[1]:.4f})")
        return True
    else:
        print(f"✗ NON-STATIONARY (fail to reject H0, p={result[1]:.4f})")
        return False

# Test all variables
kp_stationary = test_stationarity(df['kp_index'], 'Kp Index')
anxiety_stationary = test_stationarity(df['anxiety_searches'], 'Anxiety Searches')
temp_stationary = test_stationarity(df['temperature'], 'Temperature')

# %% [markdown]
# ## 5. Correlation Analysis with Bootstrap Confidence Intervals

# %%
def bootstrap_correlation(x, y, n_iterations=10000, confidence=0.95):
    """Compute correlation with bootstrap confidence interval"""
    n = len(x)
    correlations = []
    
    for _ in range(n_iterations):
        indices = np.random.choice(n, size=n, replace=True)
        x_boot = x.iloc[indices].values
        y_boot = y.iloc[indices].values
        corr, _ = stats.pearsonr(x_boot, y_boot)
        correlations.append(corr)
    
    # Compute percentile CI
    alpha = 1 - confidence
    lower = np.percentile(correlations, alpha/2 * 100)
    upper = np.percentile(correlations, (1 - alpha/2) * 100)
    
    return correlations, (lower, upper)

# Pearson correlation
corr_pearson, p_value = stats.pearsonr(df['kp_index'], df['anxiety_searches'])
print("=== Pearson Correlation Analysis ===")
print(f"Correlation coefficient: {corr_pearson:.4f}")
print(f"p-value: {p_value:.4f}")

# Bootstrap CI
bootstrap_corrs, ci = bootstrap_correlation(df['kp_index'], df['anxiety_searches'])
print(f"95% CI (bootstrap): [{ci[0]:.4f}, {ci[1]:.4f}]")

# Effect size classification
