    ('Summer months', df[df['date'].dt.month.isin([6, 7, 8])]),
    ('Winter months', df[df['date'].dt.month.isin([12, 1, 2])])
]

for period_name, period_data in periods:
    if len(period_data) < 30:
        continue
    corr, p = stats.pearsonr(period_data['kp_index'], period_data['anxiety_searches'])
    print(f"{period_name}: r={corr:.3f}, p={p:.4f}, n={len(period_data)}")

