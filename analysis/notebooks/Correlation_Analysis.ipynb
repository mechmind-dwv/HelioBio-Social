# %% [markdown]
# ## 6. Granger Causality Test
# 
# Tests if past values of Kp help predict anxiety searches,
# beyond what anxiety's own past predicts.

# %%
def granger_causality_analysis(data, x_col, y_col, max_lag=15):
    """Perform Granger causality test"""
    # Prepare data (Y, X order required)
    test_data = data[[y_col, x_col]].dropna().values
    
    print(f"\n=== Granger Causality Test: {x_col} → {y_col} ===")
    print(f"Testing lags 1 to {max_lag}")
    
    try:
        results = grangercausalitytests(test_data, maxlag=max_lag, verbose=False)
        
        # Extract best lag
        best_lag = 1
        best_p = 1.0
        
        for lag, result in results.items():
            f_test = result[0]['ssr_ftest']
            p_value = f_test[1]
            
            if p_value < best_p:
                best_lag = lag
                best_p = p_value
        
        print(f"\nOptimal lag: {best_lag} days")
        print(f"F-statistic: {results[best_lag][0]['ssr_ftest'][0]:.4f}")
        print(f"p-value: {best_p:.4f}")
        
        if best_p < 0.05:
            print(f"✓ SIGNIFICANT: {x_col} Granger-causes {y_col}")
        else:
            print(f"✗ NOT SIGNIFICANT: No Granger causality detected")
        
        return results, best_lag, best_p
        
    except Exception as e:
        print(f"Error in Granger test: {e}")
        return None, None, None

# Test Kp → Anxiety
results_forward, lag_forward, p_forward = granger_causality_analysis(
    df, 'kp_index', 'anxiety_searches', max_lag=15
)

# Test Anxiety → Kp (reverse causality check)
results_backward, lag_backward, p_backward = granger_causality_analysis(
    df, 'anxiety_searches', 'kp_index', max_lag=15
)

# Interpret bidirectional results
print("\n=== Bidirectional Granger Causality Summary ===")
print(f"Kp → Anxiety: p={p_forward:.4f}, lag={lag_forward}")
print(f"Anxiety → Kp: p={p_backward:.4f}, lag={lag_backward}")

if p_forward < 0.05 and p_backward >= 0.05:
    print("\n✓ Evidence of unidirectional causality: Kp → Anxiety")
elif p_backward < 0.05 and p_forward >= 0.05:
    print("\n⚠ Reverse causality detected: Anxiety → Kp (unexpected)")
elif p_forward < 0.05 and p_backward < 0.05:
    print("\n⚠ Bidirectional feedback detected")
else:
    print("\n✗ No significant Granger causality in either direction")

# %% [markdown]
# ## 7. Partial Correlation (Controlling for Confounders)

# %%
from sklearn.linear_model import LinearRegression

def partial_correlation(data, x_col, y_col, control_cols):
    """Compute partial correlation controlling for confounders"""
    # Residualize X and Y by control variables
    X_controls = data[control_cols].values
    
    # Residuals of x
    model_x = LinearRegression()
    model_x.fit(X_controls, data[x_col])
    x_residuals = data[x_col] - model_x.predict(X_controls)
    
    # Residuals of y
    model_y = LinearRegression()
    model_y.fit(X_controls, data[y_col])
    y_residuals = data[y_col] - model_y.predict(X_controls)
    
    # Correlate residuals
    partial_corr, p_value = stats.pearsonr(x_residuals, y_residuals)
    
    return partial_corr, p_value

# Partial correlation controlling for temperature and day of week
partial_corr, partial_p = partial_correlation(
    df,
    'kp_index',
    'anxiety_searches',
    ['temperature', 'day_of_week']
)

print("\n=== Partial Correlation Analysis ===")
print(f"Controlling for: temperature, day_of_week")
print(f"Simple correlation: {corr_pearson:.4f}")
print(f"Partial correlation: {partial_corr:.4f}")
print(f"p-value: {partial_p:.4f}")
print(f"\nChange: {abs(corr_pearson - partial_corr):.4f} ({(abs(corr_pearson - partial_corr)/abs(corr_pearson)*100):.1f}% reduction)")

